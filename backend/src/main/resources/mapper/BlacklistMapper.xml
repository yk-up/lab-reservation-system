<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lab.reservation.mapper.BlacklistMapper">

    <resultMap id="BlacklistMap" type="com.lab.reservation.entity.Blacklist">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="realName" column="real_name"/>
        <result property="reason" column="reason"/>
        <result property="operatorId" column="operator_id"/>
        <result property="expireTime" column="expire_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO blacklist (user_id, reason, operator_id, expire_time)
        VALUES (#{userId}, #{reason}, #{operatorId}, #{expireTime})
    </insert>

    <!-- 查询用户是否有效封禁：expire_time 为 null（永久）或 expire_time > now() -->
    <select id="findActiveByUserId" resultMap="BlacklistMap">
        SELECT * FROM blacklist
        WHERE user_id = #{userId}
          AND (expire_time IS NULL OR expire_time > NOW())
        ORDER BY create_time DESC
        LIMIT 1
    </select>

    <select id="findAll" resultMap="BlacklistMap">
        SELECT b.*, u.username, u.real_name
        FROM blacklist b
        LEFT JOIN `user` u ON u.id = b.user_id
        ORDER BY b.create_time DESC
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM blacklist
    </select>

    <delete id="deleteById">
        DELETE FROM blacklist WHERE id = #{id}
    </delete>

</mapper>
